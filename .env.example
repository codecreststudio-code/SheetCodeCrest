# 🔐 SheetCodeCrest Environment Variables Configuration
# Copy this file to a new file named `.env` or `.env.local` in this same directory
# and fill in your live credentials.

# 1. Supabase Credentials (from settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# 2. Stripe Payments Configuration (Optional/Individual)
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-payment-link-id

# 3. Razorpay Payments Configuration
VITE_RAZORPAY_KEY_ID=rzp_live_your_key_id
VITE_RAZORPAY_KEY_SECRET=your_razorpay_secret_if_needed # Kept client-side only if required, normally Key ID is enough for standard checkout
