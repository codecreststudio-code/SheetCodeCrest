{
  "rewrites": [
    {
      "source": "/((?!sitemap.xml|ads.txt|robots.txt|favicon.png|logo.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ]
}